{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://context-engineering/contracts/ask-codex-supervisor/request.schema.json",
  "title": "ask_codex_supervisor request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mission_id",
    "goal",
    "current_phase",
    "blocked_reason",
    "attempt_history",
    "constraints",
    "authorized_scope",
    "requested_decision"
  ],
  "properties": {
    "mission_id": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "current_phase": {
      "type": "string",
      "enum": [
        "discovery",
        "classification",
        "validation",
        "reporting"
      ]
    },
    "blocked_reason": {
      "type": "string",
      "enum": [
        "tool_error",
        "ambiguous_result",
        "policy_conflict",
        "insufficient_context",
        "repeated_failure"
      ]
    },
    "attempt_history": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string"
      }
    },
    "evidence_summary": {
      "type": "string"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "authorized_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_id",
        "targets",
        "expires_utc"
      ],
      "properties": {
        "scope_id": {
          "type": "string",
          "minLength": 1
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "expires_utc": {
          "type": "string",
          "minLength": 1,
          "description": "UTC timestamp in ISO 8601 format"
        }
      }
    },
    "requested_decision": {
      "type": "string",
      "enum": [
        "next_step",
        "prioritize",
        "deconflict",
        "stop_or_continue"
      ]
    }
  }
}
